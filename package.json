{
  "name": "mission-control",
  "version": "0.1.0",
  "description": "A self-hostable personal dashboard for homelab services.",
  "main": "src/backend/server.js",
  "scripts": {
    "start": "node src/backend/server.js",
    "dev": "NODE_ENV=development nodemon src/backend/server.js",
    "docker:build": "docker build -t mission-control-app .",
    "docker:compose:up": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "lint": "eslint . --ext .js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "mqtt": "^5.3.0",
    "sqlite3": "^5.1.7",
    "vue3-grid-layout": "^1.0.0"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "nodemon": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
