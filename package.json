{
  "name": "mission-control",
  "version": "0.1.0",
  "description": "A self-hostable personal dashboard for homelab services.",
  "main": "src/backend/server.js",
  "scripts": {
    "start": "node src/backend/server.js",
    "dev": "NODE_ENV=development nodemon src/backend/server.js",
    "docker:build": "docker build -t mission-control-app .",
    "docker:compose:up": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "lint": "eslint . --ext .js"
  },
  "dependencies": {
    "axios": "^1.6.0",         // For widgetProxyService HTTP requests
    "chokidar": "^3.5.3",      // For yamlService file watching
    "cors": "^2.8.5",          // Express middleware for CORS
    "express": "^4.18.2",      // Web server framework
    "js-yaml": "^4.1.0",       // For parsing and stringifying YAML
    "mqtt": "^5.3.0",          // MQTT client library (for backend service)
    "sqlite3": "^5.1.7"        // SQLite database driver (choose version compatible with your Node)
  },
  "devDependencies": {
    "nodemon": "^3.0.0",       // For auto-restarting server during development
    "eslint": "^8.50.0"        // Example linter, configure as needed
    // Add other dev dependencies like testing frameworks if desired
  },
  "engines": {
    "node": ">=18.0.0" // Specify minimum Node.js version compatible with dependencies
  }
}
