# .dockerignore

# Ignore Git directory
.git
.gitignore

# Ignore Node.js dependency directories (these will be installed inside the container)
node_modules/
src/frontend/node_modules/ # If frontend has its own separate node_modules

# Ignore build output directories if they are generated locally before Docker build
# The Dockerfile handles building these from source within its stages.
dist/
build/
# If your frontend build outputs to src/frontend/dist and you commit src/frontend/dist,
# then you might not ignore it here, but the Dockerfile should ideally build it fresh.
# For our Dockerfile, it builds frontend assets in a stage, so local frontend build outputs can be ignored.
src/frontend/dist/
src/frontend/build/


# User-specific data and configuration that are mounted as volumes
# These should not be part of the image.
app_data/
mosquitto_data/ # If you use the example Mosquitto service locally

# IDE and OS-specific files
.DS_Store
.idea/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log.*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
.nyc_output/

# Environment files (should never be committed or part of image)
.env
.env.*
!.env.example # Keep example env files if you have them

# Optional: ignore local development config files that aren't examples
# config.dev.yml
# settings.local.yml

# Compiled binary files (if any, less common for Node.js projects)
*.o
*.so
*.exe
*.dll

# Temporary files
*.tmp
*~
